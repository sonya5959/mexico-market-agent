# ============================================================
# .env 파일 — API 키 및 설정값
# ⚠️  이 파일은 절대 Git에 올리지 마세요! (.gitignore에 .env 포함됨)
# ============================================================

# ────────────────────────────────────────────────
# [1] Reddit API  (무료)
# 발급: https://www.reddit.com/prefs/apps
# ────────────────────────────────────────────────
REDDIT_CLIENT_ID=여기에_클라이언트_ID_입력
REDDIT_CLIENT_SECRET=여기에_클라이언트_시크릿_입력
REDDIT_USER_AGENT=MarketIntelligenceBot/1.0 by YourRedditUsername

# ────────────────────────────────────────────────
# [2] Apify API  (월 $5 무료 크레딧)
# 발급: https://console.apify.com/account/integrations
# ────────────────────────────────────────────────
APIFY_API_TOKEN=여기에_Apify_토큰_입력

# ────────────────────────────────────────────────
# [3] AI 분석 API  (둘 중 하나만 입력해도 됨)
# Anthropic: https://console.anthropic.com/
# OpenAI   : https://platform.openai.com/api-keys
# ────────────────────────────────────────────────
ANTHROPIC_API_KEY=여기에_Anthropic_키_입력
OPENAI_API_KEY=여기에_OpenAI_키_입력

# 사용할 AI 제공자: "anthropic" 또는 "openai"
AI_PROVIDER=anthropic

# ────────────────────────────────────────────────
# [4] Gmail 발송 설정  (무료 — 추가 가입 불필요)
#
# ★ GMAIL_APP_PASSWORD 발급 방법 (5분):
#   1. Gmail 로그인 → Google 계정 관리
#   2. 보안 → 2단계 인증 활성화 (필수!)
#   3. 보안 검색창에 "앱 비밀번호" 검색 → 클릭
#   4. 앱: "메일" / 기기: "기타" → 이름: "마켓봇" → 생성
#   5. 표시된 16자리 비밀번호 복사 (공백 제거 후 입력)
#      예: abcd efgh ijkl mnop → abcdefghijklmnop
# ────────────────────────────────────────────────
GMAIL_SENDER=발신에_사용할_본인_gmail@gmail.com
GMAIL_APP_PASSWORD=16자리앱비밀번호공백없이입력
GMAIL_RECIPIENT=리포트_받을_이메일@gmail.com

# ────────────────────────────────────────────────
# [5] 에이전트 동작 설정
# ────────────────────────────────────────────────
# 수집할 최근 데이터 기간 (일 단위, 기본값: 1일)
LOOKBACK_DAYS=1
